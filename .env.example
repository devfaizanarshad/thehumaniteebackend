# Server Port
PORT=3000
CORS_ORIGIN="https://thehumanitee.com"

# PostgreSQL Database URL
# Replace username, password, localhost, 5432, and dbname
DATABASE_URL="postgresql://username:password@localhost:5432/humanity_db?schema=public"

# Stripe Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
SMOKE_TEST_SECRET="replace-with-a-long-random-secret"
ALLOW_SMOKE_TEST_IN_LIVE="false"

# Store
STORE_NAME="The Humanitee"
STORE_URL="https://thehumanitee.com/"
ORDER_CURRENCY="USD"
# Optional JSON override for server-side product prices.
# PRODUCT_CATALOG_JSON='{"humanity-tee-black":{"name":"Humanity Tee Black","currency":"usd","prices":{"S":29.99,"M":29.99,"L":29.99,"XL":29.99}}}'

# Email
NODE_ENV=development
EMAIL_FROM="The Humanitee <orders@example.com>"
EMAIL_TO="admin@example.com"
ORDER_MANAGER_EMAIL="manager@example.com"
QUOTE_EMAIL_DEV="dev@example.com"
RESEND_API_KEY="re_..."
